generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Submission {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  problemId       String?   @map("problem_id")
  code            String
  language        String
  status          String
  executionTime   String?   @map("execution_time")
  memoryUsed      String?   @map("memory_used")
  created_at      DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  
  // New columns for judge system
  sourceCode      String?   @map("source_code")
  passedTestCases Int       @default(0) @map("passed_test_cases")
  totalTestCases  Int       @default(0) @map("total_test_cases")
  submittedAt     DateTime  @default(now()) @map("submitted_at")

  problems        problems? @relation(fields: [problemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles        profiles? @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("submissions")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contests {
  id           String    @id
  name         String
  status       String?   @default("upcoming")
  countdown    String?
  duration     String?
  difficulty   String?
  participants Int?      @default(0)
  problems     Json?     @default("[]")
  scoreboard   Json?     @default("[]")
  created_at   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  start_time   DateTime? @db.Timestamptz(6)
  end_time     DateTime? @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model problems {
  id             String       @id
  title          String
  difficulty     String
  acceptance     String?      @default("0.0%")
  recommended    Boolean?     @default(false)
  category       String?      @default("General")
  statement      String
  input_example  String?
  output_example String?
  constraints    Json?        @default("[]")
  starter_code   Json?        @default("{}")
  test_cases     Json?        @default("[]")
  editorial      String?      @default("")
  created_at     DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  submissions    Submission[]

  // New columns for judge system
  slug               String?      @unique
  functionName       String?      @map("function_name")
  returnType         String?      @map("return_type")
  parameters         Json?        @default("[]")
  visibleTestCases   Json?        @default("[]") @map("visible_test_cases")
  hiddenTestCases    Json?        @default("[]") @map("hidden_test_cases")
  tags               String[]     @default([])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id           String       @id @db.Uuid
  username     String       @unique
  fullname     String?
  avatar_color String?
  xp           Int?         @default(0)
  level        Int?         @default(1)
  streak       Int?         @default(0)
  created_at   DateTime?    @default(now()) @db.Timestamptz(6)
  email        String?
  password     String?
  solved_count Json?        @default("{\"easy\": 0, \"hard\": 0, \"total\": 0, \"medium\": 0}")
  skills       Json?        @default("{\"DP\": 0, \"Trees\": 0, \"Arrays\": 0, \"Graphs\": 0, \"Sorting\": 0, \"Strings\": 0}")
  submissions  Submission[]
}
