PORT=5000
JWT_SECRET=supersecretjwtkeychangeinproduction
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Supabase configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# ─── Prisma / Judge System ───────────────────────────────────────────────────
# Get connection strings from: Supabase Dashboard → Settings → Database → Connection String
# DATABASE_URL: port 6543 (Transaction Pooler) — runtime queries
# DIRECT_URL: port 5432 (Direct connection) — used by prisma db push / generate
DATABASE_URL=postgresql://postgres.[ref]:[password]@[host]:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[ref]:[password]@[host]:5432/postgres

# ─── Judge0 Execution Engine ────────────────────────────────────────────────
# For self-hosting (recommended, completely free):
JUDGE0_API_URL=http://localhost:2358
JUDGE0_API_KEY=

# For cloud hosting (Judge0 via RapidAPI):
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your_rapidapi_key_here
